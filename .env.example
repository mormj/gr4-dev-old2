# Copy to .env and adjust as needed.
GR4_ENV_NAME=local

# Host/dev ports
GR4_CONTROL_PLANE_PORT=8080
GR4_STUDIO_PORT=5173

# Service wiring
GR4_CONTROL_PLANE_URL=http://127.0.0.1:${GR4_CONTROL_PLANE_PORT}

# Workspace layout (defaults are relative to repo root)
GR4_SRC_DIR=src
GR4_BUILD_DIR=build
GR4_PREFIX_DIR=install

# Toolchain / build tools
# Uncomment to opt into the clang toolchain override used by dev-env
# GR4_CC=/opt/homebrew/opt/llvm@21/bin/clang
# GR4_CXX=/opt/homebrew/opt/llvm@21/bin/clang++
# GR4_LLVM_ROOT=/opt/homebrew/opt/llvm@21
GR4_PKGCONF=pkgconf

# Optional runtime knobs
GR4_LOG_LEVEL=info
GR4_DEBUG=0

# Docker Compose image defaults for local product images
IMAGE_NAMESPACE=gr4-dev
IMAGE_TAG=latest

# Published image example:
# IMAGE_NAMESPACE=ghcr.io/${USER}/gr4-dev

# Host ports
GR4_DOCKER_CONTROL_PLANE_PORT=8080
GR4_DOCKER_STUDIO_PORT=8088

# Advanced image overrides
# GR4_CONTROL_PLANE_IMAGE=ghcr.io/${USER}/gr4-dev/gr4-control-plane-runtime:latest
# GR4_STUDIO_IMAGE=ghcr.io/${USER}/gr4-dev/gr4-studio:latest

# Advanced runtime overrides
# GR4_DOCKER_PLUGIN_DIRECTORIES=/usr/local/lib/gnuradio-4/plugins:/usr/local/lib:/opt/gr4-control-plane/lib
# GR4_DOCKER_HOST_DATA_DIR=./data
# GR4_DOCKER_CONTAINER_DATA_DIR=/opt/gr4-control-plane/data
